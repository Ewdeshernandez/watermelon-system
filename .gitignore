# =============================================================
# Watermelon System — .gitignore
# =============================================================

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Entornos virtuales ---
.venv/
venv/
env/
.env
.envrc

# --- Editores / SO ---
.DS_Store
.vscode/
.idea/
*.swp
*.swo
Thumbs.db

# --- Logs y temporales ---
*.log
*.bak
*.save
*.tmp
*.cache

# --- Streamlit secrets (NUNCA commitear) ---
.streamlit/secrets.toml

# --- Estado de runtime de la app (no es código) ---
data/report_state.json
data/report_drafts/

# --- Document Vault (datos del usuario, NO commitear) ---
data/asset_documents/
data/asset_metadata/

# --- Document Vault SEEDS (manuales de fábrica, SÍ commitear) ---
# Esta carpeta contiene PDFs de referencia (manuales OEM, reportes
# históricos del cliente) que viven en el repo y sobreviven cualquier
# redeploy de Streamlit Cloud. Se sobrescribe la regla global *.pdf
# de más abajo para esta carpeta específica.
!data/asset_documents_seed/
!data/asset_documents_seed/**

# --- Backups manuales ---
backup_*/
backup_phase*/
*_backup_*/

# --- Outputs locales no versionables ---
exports/
*.pdf
!docs/*.pdf
!data/asset_documents_seed/**/*.pdf
